# GitHub personal access token (repo scope)
GITHUB_TOKEN=ghp_...

# Jira credentials
JIRA_USERNAME=you@redhat.com
JIRA_API_TOKEN=...

# Slack auth for message sweep (use ONE of the two options below)
#
# Option A: User API token (requires Slack App + admin approval)
# SLACK_USER_TOKEN=xoxp-...
#
# Option B: Browser session tokens (no admin approval needed)
# Extract with: https://github.com/maorfr/slack-token-extractor
SLACK_XOXC_TOKEN=xoxc-...
SLACK_XOXD_TOKEN=xoxd-...

# Vertex AI for LLM synthesis (uses Application Default Credentials)
# Run: gcloud auth application-default login
ANTHROPIC_VERTEX_PROJECT_ID=itpc-gcp-ai-eng-claude
ANTHROPIC_VERTEX_REGION=us-east5

# Google Docs publishing (service account JSON key)
# Share the target doc with the service account email as Editor
GOOGLE_DOCS_CREDENTIALS=/path/to/docs-service-account.json
