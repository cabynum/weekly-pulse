# GitHub personal access token (repo scope)
GITHUB_TOKEN=ghp_...

# Jira credentials
JIRA_USERNAME=you@redhat.com
JIRA_API_TOKEN=...

# Slack user token (search:read scope) for message sweep
SLACK_USER_TOKEN=xoxp-...

# Vertex AI for LLM synthesis (uses Application Default Credentials)
